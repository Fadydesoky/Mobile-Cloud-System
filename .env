# ============================
# Flask
# ============================
FLASK_ENV=development
DEBUG=False
LOG_LEVEL=INFO

# ============================
# App Ports
# ============================
PRODUCT_SERVICE_PORT=5001
ORDER_SERVICE_PORT=5002

# ============================
# Redis (Lab2)
# ============================
REDIS_PRIMARY_HOST=redis-primary
REDIS_PRIMARY_PORT=6379
REDIS_REPLICA_HOST=redis-replica
REDIS_REPLICA_PORT=6380

# ============================
# Microservices (Lab4)
# ============================
PRODUCT_SERVICE_URL=http://product-service:5001

# ============================
# API Behavior
# ============================
REQUEST_TIMEOUT=2
RETRY_COUNT=2
RETRY_DELAY=1

# ============================
# Simulation
# ============================
SIMULATED_DELAY_MIN=0.1
SIMULATED_DELAY_MAX=1.5

# ============================
# CORS
# ============================
CORS_ORIGINS=http://localhost:3000
